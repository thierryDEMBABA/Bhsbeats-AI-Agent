# YouTube
YOUTUBE_API_KEY=your_youtube_api_key
YOUTUBE_CHANNEL_HANDLE=@bhsbeats

# Mega (MEGAcmd doit être installé et connecté : mega-login email password)
MEGA_BEATS_ROOT_PATH=/Beats

# OneDrive (Azure App Registration avec permission Files.ReadWrite)
ONEDRIVE_TENANT_ID=your_tenant_id
ONEDRIVE_CLIENT_ID=your_client_id
ONEDRIVE_CLIENT_SECRET=your_client_secret
ONEDRIVE_REFRESH_TOKEN=your_refresh_token
ONEDRIVE_BEATS_ROOT_PATH=Beats

# Symfony API (même valeur que SYNC_API_KEY dans le .env Symfony)
SYMFONY_API_URL=https://votre-site.com/api/beats/sync
SYMFONY_API_KEY=change_me_with_a_strong_random_key
